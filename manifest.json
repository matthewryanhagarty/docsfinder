{
  "manifest_version": 3,
  "name": "docFinder",
  "version": "1.0.0",
  "description": "Identifies the documentation platform used by any website — Mintlify, Fern, GitBook, ReadMe, Docusaurus, and more.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "docFinder"
  }
}
